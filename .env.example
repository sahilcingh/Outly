# Copy this file to .env and fill in your values

# Groq API key — get free at https://console.groq.com (14,400 req/day free)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API key — no longer required (kept for reference)
# GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (Neon/Supabase/Railway)
# If not set, falls back to local SQLite
DATABASE_URL=postgresql://user:password@host/dbname

# Required on Railway/Render — set to the mounted persistent volume path
# Railway: set to /data  |  Render: set to /var/data  |  Local: leave unset
DATA_DIR=/data

# Auth — set a strong random string in production
SECRET_KEY=replace-with-a-long-random-string
# Password to access the app. If not set, auth is disabled (local dev only)
APP_PASSWORD=your-secret-password

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram → copy the token
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your personal Telegram chat ID — send /start to @userinfobot to find it
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Gmail (job application emails) ───────────────────────────────────────────
# Gmail address to send applications FROM
GMAIL_USER=you@gmail.com
# App password: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Scheduler ────────────────────────────────────────────────────────────────
# DB user_id to use for scheduled searches (default: 1, your first account)
SCHEDULER_USER_ID=1
# Set automatically by Render — used to register the Telegram webhook
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Secret to trigger /tasks/run-search from an external cron (cron-job.org etc.)
# Pick any long random string; the cron must send it as ?token=... or X-Cron-Secret.
# This is the reliable way to schedule on Render free tier (in-process scheduler
# sleeps when the service spins down; an external ping wakes it and runs the search).
CRON_SECRET=replace-with-a-long-random-string
